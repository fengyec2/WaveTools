<Page
    x:Class="WaveTools.Views.GachaViews.TempGachaView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WaveTools.Views.GachaViews"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch">

    <Page.Resources>
        <local:RankTypeToBackgroundColorConverter x:Key="RankTypeToBackgroundColorConverter"/>
        <local:CountToBackgroundColorConverter x:Key="CountToBackgroundColorConverter"/>
        <local:CountToProgressBackgroundColorConverter x:Key="CountToProgressBackgroundColorConverter"/>
        <local:CountToProgressWidthConverter x:Key="CountToProgressWidthConverter"/>
        <local:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Page.Resources>

    <Grid x:Name="TempGachaGrid"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="14*"/>
            <ColumnDefinition Width="18*"/>
            <ColumnDefinition Width="20*"/>
        </Grid.ColumnDefinitions>

        <Grid x:Name="Gacha"
              Grid.Column="0"
              Margin="0 0 8 0"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        Spacing="4">
                <TextBlock Text="记录详情"
                           FontSize="18"
                           FontWeight="Bold"/>
                <TextBlock x:Name="Gacha_UID"
                           Text="UID"
                           Foreground="{ThemeResource AppTextSecondaryBrush}"
                           VerticalAlignment="Bottom"/>
            </StackPanel>

            <ScrollViewer Grid.Row="1"
                          Margin="0 8 0 0"
                          HorizontalScrollBarVisibility="Hidden"
                          VerticalScrollBarVisibility="Hidden">
                <StackPanel x:Name="Gacha_Panel"/>
            </ScrollViewer>
        </Grid>

        <Grid x:Name="GachaInfo"
              Grid.Column="1"
              Margin="8 0 8 0"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        Spacing="4">
                <TextBlock Text="抽卡详情"
                           FontSize="18"
                           FontWeight="Bold"/>
                <TextBlock x:Name="GachaInfo_SinceLast5Star"
                           Text="SinceLast5Star"
                           Foreground="{ThemeResource AppTextSecondaryBrush}"
                           VerticalAlignment="Bottom"/>
            </StackPanel>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        Margin="0 8 0 0">
                <TextBlock x:Name="GachaInfo_Icon_Title"
                           Text="图片"
                           Width="34"
                           Margin="8 0 0 0"/>
                <TextBlock x:Name="GachaInfo_Name_Title"
                           Text="名称"
                           Width="114"
                           Margin="8 0 0 0"/>
                <TextBlock x:Name="GachaInfo_Count_Title"
                           Text="抽数"
                           Width="65"/>
                <TextBlock x:Name="GachaInfo_Remark_Title"
                           Text="信息"
                           Width="150"/>
            </StackPanel>

            <Grid Grid.Row="2"
                  Margin="0 8 0 0"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch">

                <ListView x:Name="GachaInfo_List"
                          CanBeScrollAnchor="True"
                          Margin="-8 2 -8 4"
                          SelectionMode="None"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch">

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{Binding Count, Converter={StaticResource CountToBackgroundColorConverter}}"
                                    CornerRadius="8"
                                    Margin="-8 0 -4 4"
                                    MinHeight="42">
                                <Grid MinHeight="42">

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="124"/>
                                        <ColumnDefinition Width="65"/>
                                        <ColumnDefinition Width="150"/>
                                    </Grid.ColumnDefinitions>

                                    <Border x:Name="GachaInfo_List_Progress"
                                            Grid.Column="1"
                                            Grid.ColumnSpan="3"
                                            Background="{Binding Count, Converter={StaticResource CountToProgressBackgroundColorConverter}}"
                                            Width="{Binding Count, Converter={StaticResource CountToProgressWidthConverter}}"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Stretch"
                                            CornerRadius="0,8,8,0"/>

                                    <Border Grid.Column="0"
                                            Width="42"
                                            Height="42"
                                            Background="#33000000"
                                            VerticalAlignment="Center">
                                        <Grid>
                                            <Image Source="{Binding IconSource}"
                                                   Width="42"
                                                   Height="42"
                                                   Stretch="UniformToFill"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding IsIconVisible, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                            <TextBlock Text="?"
                                                       Foreground="White"
                                                       FontWeight="Bold"
                                                       FontSize="16"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Visibility="{Binding IsPlaceholderVisible, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                        </Grid>
                                    </Border>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Name}"
                                               Foreground="White"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="8,0,8,0"/>

                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Count}"
                                               Foreground="White"
                                               VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="3"
                                               Text="{Binding Pity}"
                                               Foreground="White"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Grid x:Name="GachaInfo_List_Disable"
                      Visibility="Collapsed"
                      CornerRadius="8"
                      Canvas.ZIndex="100"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch">

                    <StackPanel Background="{ThemeResource SystemControlAcrylicElementBrush}"/>

                    <Grid VerticalAlignment="Center"
                          HorizontalAlignment="Center">
                        <StackPanel>
                            <FontIcon FontFamily="Segoe Fluent Icons"
                                      Glyph="&#xe7ba;"
                                      Height="36"
                                      Width="36"/>
                            <TextBlock Text="还未抽到过任何5星"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>

        <Grid x:Name="GachaRecords"
              Grid.Column="2"
              Margin="8 0 8 0"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        Spacing="4">
                <TextBlock Text="抽卡记录"
                           FontSize="18"
                           FontWeight="Bold"/>
                <TextBlock x:Name="GachaRecords_Count"
                           Text="Count"
                           Foreground="{ThemeResource AppTextSecondaryBrush}"
                           VerticalAlignment="Bottom"/>
            </StackPanel>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        Margin="0 8 0 0">
                <TextBlock Text="名称"
                           Width="120"
                           Margin="8 0 0 0"/>
                <TextBlock Text="星级"
                           Width="65"/>
                <TextBlock Text="日期"
                           Width="150"/>
            </StackPanel>

            <ListView x:Name="GachaRecords_List"
                      Grid.Row="2"
                      CanBeScrollAnchor="True"
                      Margin="-8 8 -8 8"
                      SelectionMode="None"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch">

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{Binding QualityLevel, Converter={StaticResource RankTypeToBackgroundColorConverter}}"
                                CornerRadius="8"
                                Margin="-8 0 -4 0">
                            <StackPanel Orientation="Horizontal"
                                        Margin="8 8 0 8">
                                <TextBlock Text="{Binding Name}"
                                           Foreground="White"
                                           Width="120"/>
                                <TextBlock Text="{Binding QualityLevel}"
                                           Foreground="White"
                                           Width="65"/>
                                <TextBlock Text="{Binding Time}"
                                           Foreground="White"
                                           Width="150"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>